generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TrackingEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventType String?  @map("event_type") @db.VarChar(50)
  contentId String?  @map("content_id") @db.VarChar(100)
  userId    String?  @map("user_id") @db.VarChar(100)
  sessionId String?  @map("session_id") @db.VarChar(100)
  metadata  Json?
  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  platform  String?  @map("platform") @db.VarChar(50)

  @@map("tracking_events")
}

model Stat {
  contentId   String   @map("content_id") @db.VarChar(100)
  platform    String   @db.VarChar(50)
  views       BigInt   @default(0)
  favorites   BigInt   @default(0)
  calendar    BigInt   @default(0)
  ctaClicks   BigInt   @default(0) @map("cta_clicks")
  impressions BigInt   @default(0)
  updatedAt   DateTime @map("updated_at") @db.Timestamptz(6)

  @@id([contentId, platform])
  @@map("stats")
}

model DailyStat {
  day             DateTime @id @db.Date
  views           BigInt   @default(0)
  ctaClicks       BigInt   @default(0) @map("cta_clicks")
  impressions     BigInt   @default(0)
  uniqueSessions  BigInt   @default(0) @map("unique_sessions")
  webEvents       BigInt   @default(0) @map("web_events")
  iosEvents       BigInt   @default(0) @map("ios_events")
  androidEvents   BigInt   @default(0) @map("android_events")
  webSessions     BigInt   @default(0) @map("web_sessions")
  iosSessions     BigInt   @default(0) @map("ios_sessions")
  androidSessions BigInt   @default(0) @map("android_sessions")
  updatedAt       DateTime @map("updated_at") @db.Timestamptz(6)

  @@map("daily_stats")
}
